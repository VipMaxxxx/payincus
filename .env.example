# Incudal environment template
# Copy to .env for local or production deployment, then replace all secrets.

# Runtime
NODE_ENV=production
# Use 127.0.0.1 when frontend and backend are on the same host.
# Use a private intranet IP when frontend Nginx and backend Node run on different hosts.
HOST=127.0.0.1
PORT=3001
# Trust X-Forwarded-* only when the backend is reachable only through trusted Nginx/internal proxy.
TRUST_PROXY=true

# Database
DATABASE_URL=postgresql://incudal:change_me_postgres_password@127.0.0.1:5432/incudal
# Do not set RESET_DATABASE in production. Production resets require the extra
# ALLOW_PRODUCTION_DATABASE_RESET=RESET_PRODUCTION_DATABASE confirmation.

# Redis
REDIS_URL=redis://:change_me_redis_password@127.0.0.1:6379

# Security
# Generate each production secret separately, for example:
# openssl rand -base64 48
JWT_SECRET=change_me_generate_with_openssl_rand_base64_48
COOKIE_SECRET=change_me_generate_with_openssl_rand_base64_48
# ENCRYPTION_KEY protects sensitive stored data. Keep it stable after first deploy.
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_48
ADMIN_PASSWORD=change_me_admin_password

# Public URLs
# Same-origin split deployment recommendation:
# FRONTEND_URL=https://panel.example.com
# PAYMENT_CALLBACK_BASE_URL=https://panel.example.com
FRONTEND_URL=https://panel.example.com
SITE_URL=https://panel.example.com
PAYMENT_CALLBACK_BASE_URL=https://panel.example.com

# Frontend/backend separation
# Set false when the backend only serves APIs and static files are hosted by Nginx/CDN.
SERVE_STATIC_CLIENT=false
# Frontend build-time variable. Leave /api for same-origin reverse proxy.
VITE_API_BASE_URL=/api
# Leave blank for HTTPS same-origin proxy mode. For HTTP-only intranet validation, set COOKIE_SECURE=false.
# For cross-site API domains, set:
# COOKIE_SAME_SITE=none
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.example.com only when sharing cookies across subdomains is required.
COOKIE_SAME_SITE=
COOKIE_SECURE=
COOKIE_DOMAIN=

# Payment callback hardening
PAYMENT_CALLBACK_IP_WHITELIST=
PAYMENT_CALLBACK_SKIP_IP_WHITELIST=false

# Logging and operations
LOG_LEVEL=info
DISABLE_REQUEST_LOG=true
ALERT_WEBHOOK_URL=

# Database pool tuning
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_CONNECTION_TIMEOUT=5000
DB_IDLE_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=30000

# Background jobs
TRAFFIC_CONCURRENCY_PER_HOST=10
TRAFFIC_HOST_CONCURRENCY=3
DB_WORKER_BACKOFF_MS=15000

# Agent release proxy
INCUDAL_AGENT_RELEASE_REPOSITORY=
INCUDAL_AGENT_RELEASE_TOKEN=
# Optional local release directory containing manifest.json and linux-amd64/linux-arm64 binaries.
INCUDAL_AGENT_RELEASE_DIR=
INCUDAL_AGENT_BINARY_URL=
INCUDAL_AGENT_BINARY_SHA256=
