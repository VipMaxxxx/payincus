# Copy this file to .env.docker before running docker compose.
# cp .env.docker.example .env.docker

# Database and Redis passwords used by docker-compose.yml.
POSTGRES_DB=payincus
POSTGRES_USER=payincus
POSTGRES_PASSWORD=change_me_postgres_password
REDIS_PASSWORD=change_me_redis_password

# Published local ports. Put a TLS reverse proxy in front of these ports in production.
USER_HTTP_PORT=8080
ADMIN_HTTP_PORT=8081
NGINX_CLIENT_MAX_BODY_SIZE=50m

# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3001
TRUST_PROXY=true
SERVE_STATIC_CLIENT=false
LOG_LEVEL=info
DISABLE_REQUEST_LOG=true

# Public URLs. Replace with real HTTPS domains in production.
FRONTEND_URL=http://localhost:8080
ADMIN_FRONTEND_URL=http://localhost:8081
SITE_URL=http://localhost:8080
PAYMENT_CALLBACK_BASE_URL=http://localhost:8080

# Frontend build-time values used by Docker image build.
VITE_API_BASE_URL=/api
VITE_CUSTOMER_BASE_URL=http://localhost:8080
VITE_ADMIN_BASE_URL=http://localhost:8081

# For local HTTP testing only. For real HTTPS production, leave COOKIE_SECURE empty or set true.
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Security secrets. Generate unique production values, for example: openssl rand -base64 48
JWT_SECRET=change_me_generate_with_openssl_rand_base64_48
COOKIE_SECRET=change_me_generate_with_openssl_rand_base64_48
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_48
PLUGIN_WEBHOOK_SIGNING_SECRET=change_me_generate_with_openssl_rand_base64_48

# Initial admin account. The first boot creates/updates the initial admin.
ADMIN_EMAIL=admin@payincus.local
ADMIN_PASSWORD=change_me_admin_password

# Payment callback hardening. Configure real provider IP ranges before enabling strict production callbacks.
PAYMENT_CALLBACK_IP_WHITELIST=
PAYMENT_CALLBACK_IP_WHITELIST_REQUIRED=true
PAYMENT_CALLBACK_SKIP_IP_WHITELIST=false

# Optional operational settings.
RUN_MIGRATIONS=true
RUN_DATA_MIGRATIONS=false
ALERT_WEBHOOK_URL=
SYSTEM_UPDATE_ALLOWED_ADMIN_IDS=
SYSTEM_UPDATE_RELEASE_REPOSITORY=VipMaxxxx/payincus
SYSTEM_UPDATE_RELEASE_TOKEN=
SYSTEM_UPDATE_APPLY_MODE=auto
PAYINCUS_GIFT_CARD_ADMIN_IDS=
PLUGIN_MANAGER_ALLOWED_ADMIN_IDS=
THEME_MANAGER_ALLOWED_ADMIN_IDS=
